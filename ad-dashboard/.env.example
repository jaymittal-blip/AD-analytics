# ──────────────────────────────────────────────────────────────────────────────
# Ad Dashboard – Environment Variables
# Copy this file to .env.local and fill in values.
# ──────────────────────────────────────────────────────────────────────────────

# Data source for ad performance data.
#
# Leave blank (default): pulls directly from the external API (paginated).
#
# Backend integration: set this to your Node.js API base URL.
#   The backend should expose:  GET /api/ads  → { ads: Ad[], fetchedAt: string }
#   (single call, no pagination needed on the client side)
#
# ADS_API_URL=http://localhost:4000/api/ads

# Optional: restrict which origins can call /api/ads
# ALLOWED_ORIGIN=https://your-domain.com
